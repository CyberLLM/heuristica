# Heuristica .htaccess
# Clean URL for AI Tools page

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect /ai-tools to /ai-tools.html
RewriteRule ^ai-tools/?$ /ai-tools.html [L,NC]

# Redirect /prompting to /prompting.html
RewriteRule ^prompting/?$ /prompting.html [L,NC]

# Redirect /sandbox to /sandbox.html
RewriteRule ^sandbox/?$ /sandbox.html [L,NC]

# Redirect /embeddings to /embeddings.html
RewriteRule ^embeddings/?$ /embeddings.html [L,NC]

# Redirect /workshop to /workshop.html
RewriteRule ^workshop/?$ /workshop.html [L,NC]

# Redirect /promptologia to /promptologia.html
RewriteRule ^promptologia/?$ /promptologia.html [L,NC]

# Redirect /quiz to /quiz.html
RewriteRule ^quiz/?$ /quiz.html [L,NC]

# Redirect /dojo to /dojo.html
RewriteRule ^dojo/?$ /dojo.html [L,NC]

# Redirect /promtologia-dojo to /promtologia-dojo.html
RewriteRule ^promtologia-dojo/?$ /promtologia-dojo.html [L,NC]

# Redirect /payment-success to /payment-success-page.html
RewriteRule ^payment-success/?$ /payment-success-page.html [L,NC]

# Redirect /platnosci-szkolenie-ai to /platnosci-szkolenie-ai.html
RewriteRule ^platnosci-szkolenie-ai/?$ /platnosci-szkolenie-ai.html [L,NC]

# Redirect main pages
RewriteRule ^kim/?$ /kim.html [L,NC]
RewriteRule ^uslugi/?$ /uslugi.html [L,NC]
RewriteRule ^klienci/?$ /klienci.html [L,NC]
RewriteRule ^inspiracje/?$ /inspiracje.html [L,NC]
RewriteRule ^narzedzia/?$ /narzedzia.html [L,NC]
RewriteRule ^polityka/?$ /polityka.html [L,NC]
RewriteRule ^regulamin/?$ /regulamin.html [L,NC]

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>